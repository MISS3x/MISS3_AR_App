{
  "expo": {
    "name": "MISS3 AR",
    "slug": "miss3-ar",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "scheme": "miss3ar",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0A0A0F"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "cz.miss3.ar",
      "infoPlist": {
        "NSCameraUsageDescription": "MISS3 AR needs camera access for augmented reality features",
        "NSPhotoLibraryUsageDescription": "MISS3 AR needs photo library access to save AR screenshots",
        "ITSAppUsesNonExemptEncryption": false,
        "NSPhotoLibraryAddUsageDescription": "Allow $(PRODUCT_NAME) to save photos",
        "NSMicrophoneUsageDescription": "Allow $(PRODUCT_NAME) to use your microphone"
      }
    },
    "android": {
      "package": "cz.miss3.ar",
      "adaptiveIcon": {
        "backgroundColor": "#0A0A0F",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      },
      "permissions": [
        "CAMERA"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "extra": {
      "eas": {
        "projectId": "7d1287a3-f179-4989-a8fa-f11230fbed4a"
      }
    },
    "plugins": [
      "expo-secure-store",
      "expo-font",
      [
        "@reactvision/react-viro",
        {
          "androidXxrMode": "AR"
        }
      ],
      "./plugins/withSceneReconstruction"
    ]
  }
}
