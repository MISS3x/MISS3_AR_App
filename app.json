{
  "expo": {
    "name": "MISS3 AR",
    "slug": "miss3-ar",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "scheme": "miss3ar",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0A0A0F"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "cz.miss3.ar",
      "infoPlist": {
        "NSCameraUsageDescription": "MISS3 AR needs camera access for augmented reality features",
        "NSPhotoLibraryUsageDescription": "MISS3 AR needs photo library access to save AR screenshots",
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "cz.miss3.ar",
      "adaptiveIcon": {
        "backgroundColor": "#0A0A0F",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      },
      "permissions": [
        "CAMERA"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "extra": {
      "eas": {
        "projectId": "d430025a-3859-42f7-9b32-840f6a2e5a42"
      }
    },
    "plugins": [
      "expo-secure-store",
      "expo-font",
      "expo-sharing"
    ]
  }
}
